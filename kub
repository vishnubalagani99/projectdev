#!/bin/bash
set -uo pipefail

# =====================================================================
# Kubernetes node setup for Amazon Linux 2 (Master or Worker)
# Adapted from the original Ubuntu/apt version to use yum/dnf, the
# CentOS docker-ce repo (which AL2 is compatible with), and the
# Kubernetes yum repo. Adds Calico install (master) and kubeadm join
# handling (worker), which the original script did not cover.
# =====================================================================

K8S_VERSION="1.34"

declare -a steps=(
    "01    | Change the Hostname                                          | Pending"
    "02    | Persistent loading of modules                                | Pending"
    "03    | Load kernel modules                                          | Pending"
    "04    | Update IP Table settings                                     | Pending"
    "05    | Apply Kernel Settings Without Reboot                         | Pending"
    "06    | Disable SELinux enforcing                                    | Pending"
    "07    | Add Docker (containerd) Repository                          | Pending"
    "08    | Install Containerd                                           | Pending"
    "09    | Configure containerd for systemd                             | Pending"
    "10    | Reload, Restart, Enable containerd                           | Pending"
    "11    | Add Kubernetes Repository                                    | Pending"
    "12    | Install kubelet, kubeadm, kubectl                            | Pending"
    "13    | Lock the installed package versions                         | Pending"
    "14    | Enable kubelet service                                       | Pending"
    "15    | Disable swap temporarily                                     | Pending"
    "16    | Make swap off permanent                                      | Pending"
    "17    | Kubernetes Node Initialization / Join                        | Pending"
    "18    | Install Calico network add-on (Master only)                 | Pending"
    "19    | Set KUBECONFIG and add it to .bashrc                          | Pending"
    "20    | Show kubectl get nodes and kubectl get pods -n kube-system     | Pending"
)

mark() { steps[$1-1]="$(printf '%02d' "$1")    | ${2}"; }

# --- Node type selection ---
echo "Please select the node type:"
echo "1) Master Node"
echo "2) Worker Node"
read -p "Enter your choice (1 or 2): " node_choice

if [ "$node_choice" -eq 1 ]; then
    node_type="MasterNode"
elif [ "$node_choice" -eq 2 ]; then
    node_type="WorkerNode"
else
    echo "Invalid choice. Exiting."
    exit 1
fi

# --- Hostname ---
while true; do
    read -p "Enter a unique hostname for this $node_type: " unique_hostname
    if [ -z "$unique_hostname" ]; then
        echo "Hostname cannot be empty. Please enter a valid hostname."
    elif [[ "$unique_hostname" =~ ^[a-zA-Z0-9-]+$ ]]; then
        break
    else
        echo "Invalid hostname. Use only letters, numbers, and dashes."
    fi
done

echo "Setting hostname to $unique_hostname ..."
sudo hostnamectl set-hostname "$unique_hostname"
mark 1 "Change the Hostname                                          | Completed"

# Step 02-03: kernel modules
echo "Loading kernel modules..."
cat <<EOF | sudo tee /etc/modules-load.d/containerd.conf
overlay
br_netfilter
EOF
mark 2 "Persistent loading of modules                                | Completed"

sudo modprobe overlay
sudo modprobe br_netfilter
mark 3 "Load kernel modules                                          | Completed"

# Step 04-05: sysctl / iptables
cat <<EOF | sudo tee /etc/sysctl.d/kubernetes.conf
net.bridge.bridge-nf-call-ip6tables = 1
net.bridge.bridge-nf-call-iptables = 1
net.ipv4.ip_forward = 1
EOF
sudo sysctl --system
mark 4 "Update IP Table settings                                     | Completed"
mark 5 "Apply Kernel Settings Without Reboot                         | Completed"

# Step 06: SELinux (AL2 ships with SELinux enabled/enforcing; Kubernetes
# networking components generally require it to be permissive)
if command -v getenforce >/dev/null 2>&1; then
    sudo setenforce 0 || true
    sudo sed -i 's/^SELINUX=enforcing/SELINUX=permissive/' /etc/selinux/config
    mark 6 "Disable SELinux enforcing                                    | Completed"
else
    mark 6 "Disable SELinux enforcing (not applicable)                   | Skipped"
fi

# Step 07-10: containerd via Docker's CentOS repo (AL2 is RHEL/CentOS
# compatible, but it reports its own releasever as "2", which doesn't
# exist on Docker's mirror. So we write the repo file manually with the
# CentOS 7 path hardcoded instead of using yum-config-manager, which
# would substitute $releasever and 404.
sudo yum install -y yum-utils
sudo rm -f /etc/yum.repos.d/docker-ce.repo
cat <<'EOF' | sudo tee /etc/yum.repos.d/docker-ce.repo
[docker-ce-stable]
name=Docker CE Stable - $basearch
baseurl=https://download.docker.com/linux/centos/7/$basearch/stable
enabled=1
gpgcheck=1
gpgkey=https://download.docker.com/linux/centos/gpg
EOF
mark 7 "Add Docker (containerd) Repository                          | Completed"

sudo yum install -y containerd.io
mark 8 "Install Containerd                                           | Completed"

sudo mkdir -p /etc/containerd
containerd config default | sudo tee /etc/containerd/config.toml >/dev/null
sudo sed -i 's/SystemdCgroup = false/SystemdCgroup = true/g' /etc/containerd/config.toml
mark 9 "Configure containerd for systemd                             | Completed"

sudo systemctl daemon-reload
sudo systemctl restart containerd
sudo systemctl enable containerd
mark 10 "Reload, Restart, Enable containerd                           | Completed"

# Step 11: Kubernetes yum repo
cat <<EOF | sudo tee /etc/yum.repos.d/kubernetes.repo
[kubernetes]
name=Kubernetes
baseurl=https://pkgs.k8s.io/core:/stable:/v${K8S_VERSION}/rpm/
enabled=1
gpgcheck=1
gpgkey=https://pkgs.k8s.io/core:/stable:/v${K8S_VERSION}/rpm/repodata/repomd.xml.key
exclude=kubelet kubeadm kubectl cri-tools kubernetes-cni
EOF
mark 11 "Add Kubernetes Repository                                    | Completed"

# Step 12: install kubelet/kubeadm/kubectl
sudo yum install -y kubelet kubeadm kubectl --disableexcludes=kubernetes
mark 12 "Install kubelet, kubeadm, kubectl                            | Completed"

# Step 13: version lock (yum equivalent of apt-mark hold)
sudo yum install -y yum-plugin-versionlock
sudo yum versionlock add kubelet kubeadm kubectl
mark 13 "Lock the installed package versions                         | Completed"

# Step 14: enable kubelet
sudo systemctl enable kubelet
mark 14 "Enable kubelet service                                       | Completed"

# Step 15-16: swap
sudo swapoff -a
mark 15 "Disable swap temporarily                                     | Completed"
sudo sed -i '/swap/d' /etc/fstab
mark 16 "Make swap off permanent                                      | Completed"

# Step 17: Master init OR Worker join
kubeadm_output=""
if [ "$node_choice" -eq 1 ]; then
    read -p "Do you want to proceed with Kubernetes MasterNode Initialization? (Yes/No): " proceed_init
    if [[ "$proceed_init" =~ ^[Yy](es)?$ ]]; then
        kubeadm_output=$(sudo kubeadm init --pod-network-cidr=192.168.0.0/16 2>&1)
        echo "$kubeadm_output"
        mark 17 "Kubernetes MasterNode Initialized                            | Completed"
    else
        mark 17 "Kubernetes MasterNode Initialization skipped                 | Skipped"
    fi
else
    echo "Paste the full 'kubeadm join ...' command copied from the Master node's"
    echo "'kubeadm init' output (includes --token and --discovery-token-ca-cert-hash)."
    read -p "kubeadm join command: " join_cmd
    if [ -n "$join_cmd" ]; then
        sudo bash -c "$join_cmd"
        mark 17 "Kubernetes Worker Node Joined                                 | Completed"
    else
        mark 17 "Kubernetes Worker Node Join skipped (no command given)       | Skipped"
    fi
fi

# Step 18: Calico (master only, and only if init succeeded)
if [ "$node_choice" -eq 1 ] && [[ -n "$kubeadm_output" ]] && echo "$kubeadm_output" | grep -q "Your Kubernetes control-plane has initialized successfully"; then
    export KUBECONFIG=/etc/kubernetes/admin.conf
    sudo -E kubectl apply -f https://raw.githubusercontent.com/projectcalico/calico/v3.28.0/manifests/calico.yaml
    mark 18 "Install Calico network add-on (Master only)                 | Completed"
elif [ "$node_choice" -eq 1 ]; then
    mark 18 "Install Calico network add-on (Master only)                 | Skipped (init not completed)"
else
    mark 18 "Install Calico network add-on (Master only)                 | Skipped (worker node)"
fi

# Step 19: KUBECONFIG persistence (master only — workers have no admin.conf)
if [ "$node_choice" -eq 1 ]; then
    if [ "$EUID" -eq 0 ]; then
        echo "export KUBECONFIG=/etc/kubernetes/admin.conf" >> /root/.bashrc
    else
        echo "export KUBECONFIG=/etc/kubernetes/admin.conf" >> ~/.bashrc
    fi
    export KUBECONFIG=/etc/kubernetes/admin.conf
    mark 19 "Set KUBECONFIG and added it to .bashrc                        | Completed"
else
    mark 19 "Set KUBECONFIG and added it to .bashrc                        | Skipped (worker node)"
fi

# Step 20: verification (master only, since workers can't query the API server without the kubeconfig)
if [ "$node_choice" -eq 1 ]; then
    sudo -E kubectl get nodes
    sudo -E kubectl get pods -n kube-system
    mark 20 "Show kubectl get nodes and kubectl get pods -n kube-system   | Completed"
else
    mark 20 "Show kubectl get nodes and kubectl get pods -n kube-system   | Skipped (worker node)"
fi

# --- Final status table ---
echo -e "+-------+------------------------------------------------------------+-----------------+"
echo -e "| Step  | Description                                              | Process State   |"
echo -e "+-------+------------------------------------------------------------+-----------------+"
for step in "${steps[@]}"; do
    echo -e "| $step"
done

if [ "$node_choice" -eq 1 ] && [[ -n "$kubeadm_output" ]]; then
    echo -e "+-------+------------------------------------------------------------+-----------------+"
    echo -e "| Final Output of kubeadm init                                |"
    echo -e "+-------+------------------------------------------------------------+-----------------+"
    echo "$kubeadm_output" | while IFS= read -r line; do
        echo -e "| $line"
    done
    echo -e "+-------+------------------------------------------------------------+-----------------+"
fi

if [ "$node_choice" -eq 1 ]; then
    echo "Master Node setup completed!"
else
    echo "Worker Node setup completed!"
fi
