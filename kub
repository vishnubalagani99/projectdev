#!/bin/bash
set -uo pipefail

# =====================================================================
# Kubernetes node setup for Amazon Linux 2 (Master or Worker)
# v2 — fixes discovered while running this live on real EC2 nodes:
#   - containerd.io fails to install on AL2 because it depends on
#     container-selinux, which does not exist in AL2's repos or on
#     any live CentOS mirror anymore. Worked around by downloading
#     the RPM directly and installing with --nodeps (safe since
#     SELinux is set to permissive earlier in this same script).
#   - Every critical step now actually checks its exit code / real
#     state (e.g. containerd socket existing, kubeadm init succeeding)
#     instead of unconditionally marking "Completed" like the v1
#     script did, which let real failures hide behind a green table.
#   - Adds the node's own hostname to /etc/hosts to remove the
#     "hostname could not be reached" preflight warning.
#   - Worker flow now validates the pasted join command actually
#     starts with "kubeadm join" before running it.
# =====================================================================

K8S_VERSION="1.34"
CALICO_VERSION="v3.28.0"

declare -a steps=(
    "01    | Change the Hostname                                          | Pending"
    "02    | Persistent loading of modules                                | Pending"
    "03    | Load kernel modules                                          | Pending"
    "04    | Update IP Table settings                                     | Pending"
    "05    | Apply Kernel Settings Without Reboot                         | Pending"
    "06    | Disable SELinux enforcing                                    | Pending"
    "07    | Add Docker (containerd) Repository                          | Pending"
    "08    | Install Containerd                                           | Pending"
    "09    | Configure containerd for systemd                             | Pending"
    "10    | Reload, Restart, Enable containerd                           | Pending"
    "11    | Add Kubernetes Repository                                    | Pending"
    "12    | Install kubelet, kubeadm, kubectl                            | Pending"
    "13    | Lock the installed package versions                         | Pending"
    "14    | Enable kubelet service                                       | Pending"
    "15    | Disable swap temporarily                                     | Pending"
    "16    | Make swap off permanent                                      | Pending"
    "17    | Kubernetes Node Initialization / Join                        | Pending"
    "18    | Install Calico network add-on (Master only)                 | Pending"
    "19    | Set KUBECONFIG and add it to .bashrc                          | Pending"
    "20    | Show kubectl get nodes and kubectl get pods -n kube-system     | Pending"
)

mark() { steps[$1-1]="$(printf '%02d' "$1")    | ${2}"; }

die() {
    echo ""
    echo "!! FATAL: $1"
    echo "!! Fix the issue above and re-run the script (it's safe to re-run)."
    print_table
    exit 1
}

print_table() {
    echo -e "+-------+------------------------------------------------------------+-----------------+"
    echo -e "| Step  | Description                                              | Process State   |"
    echo -e "+-------+------------------------------------------------------------+-----------------+"
    for step in "${steps[@]}"; do
        echo -e "| $step"
    done
}

# --- Node type selection ---
echo "Please select the node type:"
echo "1) Master Node"
echo "2) Worker Node"
read -p "Enter your choice (1 or 2): " node_choice

if [ "$node_choice" -eq 1 ]; then
    node_type="MasterNode"
elif [ "$node_choice" -eq 2 ]; then
    node_type="WorkerNode"
else
    echo "Invalid choice. Exiting."
    exit 1
fi

# --- Hostname ---
while true; do
    read -p "Enter a unique hostname for this $node_type: " unique_hostname
    if [ -z "$unique_hostname" ]; then
        echo "Hostname cannot be empty. Please enter a valid hostname."
    elif [[ "$unique_hostname" =~ ^[a-zA-Z0-9-]+$ ]]; then
        break
    else
        echo "Invalid hostname. Use only letters, numbers, and dashes."
    fi
done

echo "Setting hostname to $unique_hostname ..."
sudo hostnamectl set-hostname "$unique_hostname" || die "Could not set hostname"

# Fix: add self-hostname to /etc/hosts to remove kubeadm's
# "hostname could not be reached" preflight warning
if ! grep -q "$unique_hostname" /etc/hosts; then
    echo "127.0.0.1 $unique_hostname" | sudo tee -a /etc/hosts >/dev/null
fi
mark 1 "Change the Hostname                                          | Completed"

# Step 02-03: kernel modules
echo "Loading kernel modules..."
cat <<EOF | sudo tee /etc/modules-load.d/containerd.conf >/dev/null
overlay
br_netfilter
EOF
mark 2 "Persistent loading of modules                                | Completed"

sudo modprobe overlay || die "modprobe overlay failed"
sudo modprobe br_netfilter || die "modprobe br_netfilter failed"
mark 3 "Load kernel modules                                          | Completed"

# Step 04-05: sysctl / iptables
cat <<EOF | sudo tee /etc/sysctl.d/kubernetes.conf >/dev/null
net.bridge.bridge-nf-call-ip6tables = 1
net.bridge.bridge-nf-call-iptables = 1
net.ipv4.ip_forward = 1
EOF
sudo sysctl --system >/dev/null || die "sysctl --system failed"
mark 4 "Update IP Table settings                                     | Completed"
mark 5 "Apply Kernel Settings Without Reboot                         | Completed"

# Step 06: SELinux (AL2 ships with SELinux enabled/enforcing; also
# needed so we can safely --nodeps install containerd.io in step 8
# without the missing container-selinux dependency mattering)
if command -v getenforce >/dev/null 2>&1; then
    sudo setenforce 0 2>/dev/null || true
    if [ -f /etc/selinux/config ]; then
        sudo sed -i 's/^SELINUX=enforcing/SELINUX=permissive/' /etc/selinux/config
    fi
    mark 6 "Disable SELinux enforcing                                    | Completed"
else
    mark 6 "Disable SELinux enforcing (not applicable)                   | Skipped"
fi

# Step 07: Docker/containerd repo — hardcoded to CentOS 7 path.
# AL2 reports its own releasever as "2", which does not exist on
# Docker's mirror, so yum-config-manager's auto-substitution 404s.
sudo yum install -y yum-utils || die "Could not install yum-utils"
sudo rm -f /etc/yum.repos.d/docker-ce.repo
cat <<'EOF' | sudo tee /etc/yum.repos.d/docker-ce.repo >/dev/null
[docker-ce-stable]
name=Docker CE Stable - $basearch
baseurl=https://download.docker.com/linux/centos/7/$basearch/stable
enabled=1
gpgcheck=1
gpgkey=https://download.docker.com/linux/centos/gpg
EOF
mark 7 "Add Docker (containerd) Repository                          | Completed"

# Step 08: Install containerd.
# containerd.io depends on container-selinux >= 2:2.74, which does
# not exist in AL2's repos and is no longer available from any live
# CentOS mirror. Try the normal install first; if that fails on the
# missing dependency, fall back to downloading the RPM directly and
# installing with --nodeps (safe here since SELinux is permissive).
sudo rpm --import https://download.docker.com/linux/centos/gpg 2>/dev/null || true
if ! rpm -q containerd.io >/dev/null 2>&1; then
    if ! sudo yum install -y containerd.io; then
        echo "Normal install failed (likely missing container-selinux on AL2)."
        echo "Falling back to direct RPM download with --nodeps..."
        yumdownloader containerd.io --destdir=/tmp || die "yumdownloader could not fetch containerd.io"
        sudo rpm -ivh --nodeps /tmp/containerd.io-*.rpm || die "rpm install of containerd.io failed"
    fi
fi
rpm -q containerd.io >/dev/null 2>&1 || die "containerd.io is still not installed"
mark 8 "Install Containerd                                           | Completed"

# Step 09: configure containerd for systemd cgroups
sudo mkdir -p /etc/containerd
containerd config default | sudo tee /etc/containerd/config.toml >/dev/null
sudo sed -i 's/SystemdCgroup = false/SystemdCgroup = true/g' /etc/containerd/config.toml
mark 9 "Configure containerd for systemd                             | Completed"

# Step 10: start containerd and actually verify it came up
sudo systemctl daemon-reload
sudo systemctl enable containerd >/dev/null 2>&1
sudo systemctl restart containerd

for i in $(seq 1 10); do
    if [ -S /var/run/containerd/containerd.sock ]; then
        break
    fi
    sleep 1
done
[ -S /var/run/containerd/containerd.sock ] || die "containerd.sock never appeared — run 'sudo journalctl -xeu containerd' to see why"
sudo systemctl is-active --quiet containerd || die "containerd service is not active — run 'sudo systemctl status containerd'"
mark 10 "Reload, Restart, Enable containerd                           | Completed"

# Step 11: Kubernetes yum repo
cat <<EOF | sudo tee /etc/yum.repos.d/kubernetes.repo >/dev/null
[kubernetes]
name=Kubernetes
baseurl=https://pkgs.k8s.io/core:/stable:/v${K8S_VERSION}/rpm/
enabled=1
gpgcheck=1
gpgkey=https://pkgs.k8s.io/core:/stable:/v${K8S_VERSION}/rpm/repodata/repomd.xml.key
exclude=kubelet kubeadm kubectl cri-tools kubernetes-cni
EOF
mark 11 "Add Kubernetes Repository                                    | Completed"

# Step 12: install kubelet/kubeadm/kubectl
sudo yum install -y kubelet kubeadm kubectl --disableexcludes=kubernetes || die "Failed to install kubelet/kubeadm/kubectl"
mark 12 "Install kubelet, kubeadm, kubectl                            | Completed"

# Step 13: version lock (yum equivalent of apt-mark hold)
sudo yum install -y yum-plugin-versionlock || die "Failed to install yum-plugin-versionlock"
sudo yum versionlock add kubelet kubeadm kubectl >/dev/null 2>&1 || true
mark 13 "Lock the installed package versions                         | Completed"

# Step 14: enable kubelet
sudo systemctl enable kubelet >/dev/null 2>&1
mark 14 "Enable kubelet service                                       | Completed"

# Step 15-16: swap
sudo swapoff -a
mark 15 "Disable swap temporarily                                     | Completed"
sudo sed -i '/swap/d' /etc/fstab
mark 16 "Make swap off permanent                                      | Completed"

# Step 17: Master init OR Worker join
kubeadm_output=""
join_succeeded=0
init_succeeded=0

if [ "$node_choice" -eq 1 ]; then
    read -p "Do you want to proceed with Kubernetes MasterNode Initialization? (Yes/No): " proceed_init
    if [[ "$proceed_init" =~ ^[Yy](es)?$ ]]; then
        kubeadm_output=$(sudo kubeadm init --pod-network-cidr=192.168.0.0/16 2>&1)
        echo "$kubeadm_output"
        if echo "$kubeadm_output" | grep -q "Your Kubernetes control-plane has initialized successfully"; then
            init_succeeded=1
            mark 17 "Kubernetes MasterNode Initialized                            | Completed"
        else
            mark 17 "Kubernetes MasterNode Initialization                        | FAILED"
            echo ""
            echo "!! kubeadm init failed. Common fixes:"
            echo "   - containerd not actually running: sudo systemctl status containerd"
            echo "   - leftover state from a previous failed attempt: sudo kubeadm reset -f, then re-run this script"
            print_table
            exit 1
        fi
    else
        mark 17 "Kubernetes MasterNode Initialization skipped                 | Skipped"
    fi
else
    echo "Paste the full 'kubeadm join ...' command copied from the Master node's"
    echo "'kubeadm init' output (includes --token and --discovery-token-ca-cert-hash)."
    echo "(Tip: run 'kubeadm token create --print-join-command' on the master if you need a fresh one.)"
    read -p "kubeadm join command: " join_cmd

    if [ -z "$join_cmd" ]; then
        mark 17 "Kubernetes Worker Node Join skipped (no command given)       | Skipped"
    elif [[ "$join_cmd" != kubeadm\ join* ]]; then
        die "That doesn't look like a 'kubeadm join ...' command — got: $join_cmd"
    else
        # Clear out any state from a previous failed join attempt
        sudo kubeadm reset -f >/dev/null 2>&1 || true
        if sudo bash -c "$join_cmd"; then
            join_succeeded=1
            mark 17 "Kubernetes Worker Node Joined                                 | Completed"
        else
            mark 17 "Kubernetes Worker Node Join                                   | FAILED"
            die "kubeadm join failed — check the error above (common cause: master's security group blocking port 6443, or an expired token)"
        fi
    fi
fi

# Step 18: Calico (master only, and only if init actually succeeded)
if [ "$node_choice" -eq 1 ] && [ "$init_succeeded" -eq 1 ]; then
    export KUBECONFIG=/etc/kubernetes/admin.conf
    if sudo -E kubectl apply -f "https://raw.githubusercontent.com/projectcalico/calico/${CALICO_VERSION}/manifests/calico.yaml"; then
        mark 18 "Install Calico network add-on (Master only)                 | Completed"
    else
        mark 18 "Install Calico network add-on (Master only)                 | FAILED"
    fi
elif [ "$node_choice" -eq 1 ]; then
    mark 18 "Install Calico network add-on (Master only)                 | Skipped (init not completed)"
else
    mark 18 "Install Calico network add-on (Master only)                 | Skipped (worker node)"
fi

# Step 19: KUBECONFIG persistence (master only — workers have no admin.conf)
if [ "$node_choice" -eq 1 ] && [ "$init_succeeded" -eq 1 ]; then
    mkdir -p "$HOME/.kube"
    sudo cp -f /etc/kubernetes/admin.conf "$HOME/.kube/config"
    sudo chown "$(id -u)":"$(id -g)" "$HOME/.kube/config"
    if [ "$EUID" -eq 0 ]; then
        grep -q "KUBECONFIG=/etc/kubernetes/admin.conf" /root/.bashrc || echo "export KUBECONFIG=/etc/kubernetes/admin.conf" >> /root/.bashrc
    else
        grep -q "KUBECONFIG=/etc/kubernetes/admin.conf" ~/.bashrc || echo "export KUBECONFIG=/etc/kubernetes/admin.conf" >> ~/.bashrc
    fi
    export KUBECONFIG=/etc/kubernetes/admin.conf
    mark 19 "Set KUBECONFIG and added it to .bashrc                        | Completed"
else
    mark 19 "Set KUBECONFIG and added it to .bashrc                        | Skipped"
fi

# Step 20: verification (master only — workers can't query the API
# server without the admin kubeconfig)
if [ "$node_choice" -eq 1 ] && [ "$init_succeeded" -eq 1 ]; then
    sudo -E kubectl get nodes
    sudo -E kubectl get pods -n kube-system
    mark 20 "Show kubectl get nodes and kubectl get pods -n kube-system   | Completed"
else
    mark 20 "Show kubectl get nodes and kubectl get pods -n kube-system   | Skipped"
fi

# --- Final status table ---
print_table

if [ "$node_choice" -eq 1 ] && [[ -n "$kubeadm_output" ]]; then
    echo -e "+-------+------------------------------------------------------------+-----------------+"
    echo -e "| Final Output of kubeadm init                                |"
    echo -e "+-------+------------------------------------------------------------+-----------------+"
    echo "$kubeadm_output" | while IFS= read -r line; do
        echo -e "| $line"
    done
    echo -e "+-------+------------------------------------------------------------+-----------------+"
fi

if [ "$node_choice" -eq 1 ]; then
    if [ "$init_succeeded" -eq 1 ]; then
        echo "Master Node setup completed successfully!"
        echo "Get a fresh join command any time with:"
        echo "  kubeadm token create --print-join-command"
    else
        echo "Master Node setup did NOT complete (init was skipped or not run)."
    fi
else
    if [ "$join_succeeded" -eq 1 ]; then
        echo "Worker Node setup completed successfully!"
    else
        echo "Worker Node setup did NOT complete (join was skipped or not run)."
    fi
fi
